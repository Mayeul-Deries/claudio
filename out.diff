+            if d['max_input_channels'] > 0:
+                print(f"[Recorder] Using manually selected device [{preferred_index}]: {d['name']}", file=sys.stderr)
+                return preferred_index
+        except (IndexError, TypeError):
+            pass
+
+    # 2. Auto-pick logic
